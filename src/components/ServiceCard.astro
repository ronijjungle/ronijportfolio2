---
// ─────────────────────────────────────────────────────────
// Service Card — "Offering Block"
// Numbered index in off-white, description in mid-grey.
// ─────────────────────────────────────────────────────────

interface Props {
  title: string;
  description: string;
  index: number;
  body: string;
}

const { title, description, index, body } = Astro.props;
const displayIndex = String(index).padStart(2, "0");
---

<article class="group border-t border-brand-dark-grey/30 pt-8">
  <p class="text-micro text-brand-off-white tracking-widest mb-4">{displayIndex}</p>
  <h3 class="text-heading mb-4 group-hover:text-brand-light-grey transition-colors duration-300">
    {title}
  </h3>
  <p class="text-body text-brand-mid-grey mb-4">
    {description}
  </p>
  <p class="text-body text-brand-dark-grey">
    {body}
  </p>
</article>
