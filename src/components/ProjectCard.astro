---
// ─────────────────────────────────────────────────────────
// Project Card — Bratus-style work listing
//
// Supports both dark and light backgrounds via `variant` prop.
// ─────────────────────────────────────────────────────────

interface Props {
  title: string;
  description: string;
  category: string;
  year: string;
  tags: string[];
  slug: string;
  thumbnail?: string;
  variant?: "dark" | "light";
}

const { title, description, category, year, tags, slug, thumbnail, variant = "dark" } = Astro.props;
const isLight = variant === "light";
---

<article class="group">
  <a href={`/portfolio/${slug}`} class="block">
    <!-- Image area -->
    <div class:list={[
      "aspect-[16/10] mb-5 overflow-hidden relative transition-colors duration-300",
      isLight
        ? "bg-brand-black/5 border border-brand-black/10 group-hover:border-brand-black/25"
        : "bg-brand-off-black border border-brand-dark-grey/15 group-hover:border-brand-dark-grey/40",
    ]}>
      {thumbnail ? (
        <img src={thumbnail} alt={title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center">
          <span class:list={[
            "text-heading transition-colors duration-300",
            isLight
              ? "text-brand-black/15 group-hover:text-brand-black/30"
              : "text-brand-dark-grey/50 group-hover:text-brand-dark-grey",
          ]}>
            {title}
          </span>
        </div>
      )}
    </div>

    <!-- Meta -->
    <div class="flex items-start justify-between gap-4 mb-2">
      <h3 class:list={[
        "text-heading-lg transition-colors duration-200",
        isLight
          ? "text-brand-black group-hover:text-brand-dark-grey"
          : "text-brand-off-white group-hover:text-brand-light-grey",
      ]}>
        {title}
      </h3>
      <span class:list={[
        "text-micro mt-1.5 shrink-0",
        isLight ? "text-brand-dark-grey" : "text-brand-dark-grey",
      ]}>{year}</span>
    </div>

    <!-- Category + tags row -->
    <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
      <span class:list={["text-caption", isLight ? "text-brand-dark-grey" : "text-brand-mid-grey"]}>{category}</span>
      {tags.length > 0 && (
        <>
          <span class:list={[isLight ? "text-brand-black/20" : "text-brand-dark-grey/40"]} aria-hidden="true">/</span>
          {tags.map((tag, i) => (
            <>
              <span class:list={["text-caption", isLight ? "text-brand-mid-grey" : "text-brand-dark-grey"]}>{tag}</span>
              {i < tags.length - 1 && <span class:list={[isLight ? "text-brand-black/15" : "text-brand-dark-grey/30"]} aria-hidden="true">,</span>}
            </>
          ))}
        </>
      )}
    </div>
  </a>
</article>
