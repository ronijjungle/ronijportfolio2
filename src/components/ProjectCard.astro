---
// ─────────────────────────────────────────────────────────
// Project Card — Bratus-style work listing
//
// Title + category + service tags. Entire card is clickable.
// Minimal chrome — content speaks for itself.
// ─────────────────────────────────────────────────────────

interface Props {
  title: string;
  description: string;
  category: string;
  year: string;
  tags: string[];
  slug: string;
}

const { title, description, category, year, tags, slug } = Astro.props;
---

<article class="group">
  <a href={`/portfolio/${slug}`} class="block">
    <!-- Image area -->
    <div class="aspect-[16/10] bg-brand-off-black border border-brand-dark-grey/15 mb-5 overflow-hidden relative group-hover:border-brand-dark-grey/40 transition-colors duration-300">
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-heading text-brand-dark-grey/50 group-hover:text-brand-dark-grey transition-colors duration-300">
          {title}
        </span>
      </div>
    </div>

    <!-- Meta -->
    <div class="flex items-start justify-between gap-4 mb-2">
      <h3 class="text-heading-lg group-hover:text-brand-light-grey transition-colors duration-200">
        {title}
      </h3>
      <span class="text-micro text-brand-dark-grey mt-1.5 shrink-0">{year}</span>
    </div>

    <!-- Category + tags row -->
    <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
      <span class="text-caption text-brand-mid-grey">{category}</span>
      {tags.length > 0 && (
        <>
          <span class="text-brand-dark-grey/40" aria-hidden="true">/</span>
          {tags.map((tag, i) => (
            <>
              <span class="text-caption text-brand-dark-grey">{tag}</span>
              {i < tags.length - 1 && <span class="text-brand-dark-grey/30" aria-hidden="true">,</span>}
            </>
          ))}
        </>
      )}
    </div>
  </a>
</article>
