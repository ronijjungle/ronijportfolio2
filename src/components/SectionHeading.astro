---
// ─────────────────────────────────────────────────────────
// Section Heading — "Brand Title Block"
// Label in mid-grey, title in off-white, description in mid-grey.
// ─────────────────────────────────────────────────────────

interface Props {
  label?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { label, title, description, align = "left" } = Astro.props;
---

<div class:list={["mb-16 md:mb-22", align === "center" && "text-center"]}>
  {label && (
    <p class="text-micro uppercase text-brand-dark-grey mb-4">
      {label}
    </p>
  )}
  <h2 class:list={[align === "center" && "mx-auto"]}>
    {title}
  </h2>
  {description && (
    <p class:list={[
      "text-body-lg text-brand-mid-grey mt-6 max-w-2xl",
      align === "center" && "mx-auto",
    ]}>
      {description}
    </p>
  )}
  <div class:list={["brand-divider mt-6", align === "center" && "mx-auto"]} aria-hidden="true"></div>
</div>
