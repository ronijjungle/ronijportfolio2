---
// ─────────────────────────────────────────────────────────
// Footer — Bratus-style multi-column layout
//
// Logo + physical details + contact + social.
// Clean, informational, no decoration.
// ─────────────────────────────────────────────────────────

import contact from "@data/contact.json";
---

<footer class="divider">
  <div class="page-container py-14 md:py-18">
    <!-- Top row: 4-column grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand -->
      <div>
        <a href="/" class="text-brand-off-white font-semibold text-lg tracking-tight inline-block mb-4">
          Ronij Barahi<span class="text-brand-mid-grey align-super text-[0.5rem] ml-0.5">&reg;</span>
        </a>
        <p class="text-caption text-brand-dark-grey leading-relaxed">
          Creative Designer<br />&amp; Brand Strategist
        </p>
      </div>

      <!-- Location -->
      <div>
        <p class="text-micro uppercase text-brand-dark-grey mb-3">Location</p>
        <p class="text-caption text-brand-mid-grey leading-relaxed">
          {contact.location}
        </p>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-micro uppercase text-brand-dark-grey mb-3">Contact</p>
        <ul class="space-y-1.5">
          <li>
            <a href={`mailto:${contact.email}`} class="text-caption text-brand-mid-grey hover:text-brand-off-white transition-colors">
              {contact.email}
            </a>
          </li>
          <li>
            <a href={`tel:${contact.phone.replace(/\D/g, "")}`} class="text-caption text-brand-mid-grey hover:text-brand-off-white transition-colors">
              {contact.phone}
            </a>
          </li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <p class="text-micro uppercase text-brand-dark-grey mb-3">Social</p>
        <ul class="space-y-1.5">
          {Object.entries(contact.social).map(([platform, url]) => (
            <li>
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-caption text-brand-mid-grey hover:text-brand-off-white transition-colors"
                aria-label={`${platform} profile`}
              >
                {platform.charAt(0).toUpperCase() + platform.slice(1)}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="divider mt-12 pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-micro text-brand-dark-grey">
        &copy; {new Date().getFullYear()} Ronij Barahi. All rights reserved.
      </p>
      <nav class="flex gap-6" aria-label="Footer navigation">
        {[
          { label: "Work", href: "/portfolio" },
          { label: "About", href: "/about" },
          { label: "Contact", href: "/contact" },
        ].map((link) => (
          <a href={link.href} class="text-micro text-brand-dark-grey hover:text-brand-off-white transition-colors">
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>
