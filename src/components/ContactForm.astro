---
// ─────────────────────────────────────────────────────────
// Contact Form — Clean, minimal inputs
// Dark borders, off-white focus, generous spacing.
// ─────────────────────────────────────────────────────────

const inputClasses =
  "w-full bg-transparent border-b border-brand-dark-grey/40 py-4 text-body text-brand-light-grey placeholder:text-brand-dark-grey focus:border-brand-off-white focus:outline-none transition-colors";
---

<form
  action="https://formspree.io/f/your-form-id"
  method="POST"
  class="space-y-6"
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="name" class="sr-only">Full Name</label>
      <input
        type="text"
        id="name"
        name="name"
        placeholder="Name"
        required
        autocomplete="name"
        class={inputClasses}
      />
    </div>
    <div>
      <label for="email" class="sr-only">Email Address</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="Email"
        required
        autocomplete="email"
        class={inputClasses}
      />
    </div>
  </div>

  <div>
    <label for="subject" class="sr-only">Subject</label>
    <input
      type="text"
      id="subject"
      name="subject"
      placeholder="Subject"
      class={inputClasses}
    />
  </div>

  <div>
    <label for="message" class="sr-only">Message</label>
    <textarea
      id="message"
      name="message"
      placeholder="Tell me about your project..."
      required
      rows={6}
      class={`${inputClasses} resize-none`}
    ></textarea>
  </div>

  <div class="pt-4">
    <button
      type="submit"
      class="inline-flex items-center gap-2 px-8 py-3 bg-brand-off-white text-brand-black text-caption uppercase font-semibold hover:bg-brand-light-grey transition-colors duration-200"
    >
      Send Message
      <span aria-hidden="true">&rarr;</span>
    </button>
  </div>
</form>
