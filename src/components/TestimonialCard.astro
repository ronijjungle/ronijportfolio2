---
// ─────────────────────────────────────────────────────────
// Testimonial Card — "Client Voice Block"
// Large quote mark in off-white, quote text in light-grey.
// ─────────────────────────────────────────────────────────

interface Props {
  name: string;
  role: string;
  company: string;
  quote: string;
}

const { name, role, company, quote } = Astro.props;
---

<blockquote class="border-t border-brand-dark-grey/30 pt-8">
  <p class="text-brand-off-white text-display-xl leading-none mb-6" aria-hidden="true">&ldquo;</p>
  <p class="text-body-lg text-brand-light-grey mb-8 font-light">
    {quote}
  </p>
  <footer class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-full bg-brand-off-black border border-brand-dark-grey/30 flex items-center justify-center">
      <span class="text-caption text-brand-mid-grey font-bold">
        {name.charAt(0)}
      </span>
    </div>
    <div>
      <cite class="not-italic text-body font-medium text-brand-off-white">{name}</cite>
      <p class="text-micro text-brand-dark-grey">{role}, {company}</p>
    </div>
  </footer>
</blockquote>
