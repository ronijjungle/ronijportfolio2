---
// ─────────────────────────────────────────────────────────
// Header — Ultra-minimal navigation (bratus-style)
//
// Logo left, 3 primary links right. Nothing more.
// Fixed position, transparent feel, barely there.
// ─────────────────────────────────────────────────────────

const navLinks = [
  { label: "Work", href: "/portfolio" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 mix-blend-difference">
  <nav
    class="page-container flex items-center justify-between h-14 md:h-18"
    aria-label="Primary navigation"
  >
    <a
      href="/"
      class="text-brand-off-white font-semibold text-lg tracking-tight hover:opacity-70 transition-opacity"
    >
      Ronij Barahi<span class="text-brand-mid-grey align-super text-[0.5rem] ml-0.5">&reg;</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-10">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "text-caption link-underline",
              currentPath.startsWith(link.href)
                ? "text-brand-off-white"
                : "text-brand-mid-grey hover:text-brand-off-white",
            ]}
            aria-current={currentPath.startsWith(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 -mr-2 text-brand-off-white"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="4" y1="8" x2="20" y2="8" />
        <line x1="4" y1="16" x2="20" y2="16" />
      </svg>
      <svg id="close-icon" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 top-14 bg-brand-black z-40 flex flex-col items-start justify-center px-6 gap-6 opacity-0 pointer-events-none transition-opacity duration-200"
    aria-hidden="true"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          "text-display",
          currentPath.startsWith(link.href)
            ? "text-brand-off-white"
            : "text-brand-mid-grey hover:text-brand-off-white transition-colors",
        ]}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<!-- Spacer -->
<div class="h-14 md:h-18" aria-hidden="true"></div>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const menuIcon = document.getElementById("menu-icon")!;
  const closeIcon = document.getElementById("close-icon")!;
  let open = false;

  toggle.addEventListener("click", () => {
    open = !open;
    toggle.setAttribute("aria-expanded", String(open));
    menu.setAttribute("aria-hidden", String(!open));
    menuIcon.classList.toggle("hidden", open);
    closeIcon.classList.toggle("hidden", !open);

    if (open) {
      menu.classList.remove("opacity-0", "pointer-events-none");
      menu.classList.add("opacity-100", "pointer-events-auto");
    } else {
      menu.classList.add("opacity-0", "pointer-events-none");
      menu.classList.remove("opacity-100", "pointer-events-auto");
    }
  });
</script>
