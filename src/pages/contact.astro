---
// ─────────────────────────────────────────────────────────
// Contact — Bratus-style: direct, information-rich
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import ContactForm from "@components/ContactForm.astro";
import contact from "@data/contact.json";
---

<Base title="Contact" description="Get in touch with Ronij Barahi.">

  <!-- Hero -->
  <section class="page-container pt-16 md:pt-26 pb-18 md:pb-30">
    <h1 class="text-display-lg max-w-4xl mb-8">Let&rsquo;s create something together</h1>
    <p class="text-body-xl text-brand-mid-grey max-w-2xl">
      Whether you have a fully formed brief or just the spark of an idea, I&rsquo;d love to hear from you.
    </p>
  </section>

  <!-- Contact grid -->
  <section class="divider">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8">

        <!-- Left: contact details -->
        <div class="lg:col-span-5">
          <div class="space-y-10">
            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-3">Email</p>
              <a href={`mailto:${contact.email}`} class="text-heading-lg text-brand-off-white link-underline">
                {contact.email}
              </a>
            </div>

            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-3">Phone</p>
              <a href={`tel:${contact.phone.replace(/\D/g, "")}`} class="text-heading text-brand-off-white link-underline">
                {contact.phone}
              </a>
            </div>

            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-3">Location</p>
              <p class="text-body-lg text-brand-light-grey">{contact.location}</p>
            </div>

            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-3">Availability</p>
              <p class="text-body-lg text-brand-light-grey">{contact.availability}</p>
            </div>

            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-4">Social</p>
              <div class="flex flex-wrap gap-x-6 gap-y-2">
                {Object.entries(contact.social).map(([platform, url]) => (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white"
                  >
                    {platform.charAt(0).toUpperCase() + platform.slice(1)}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div class="lg:col-span-7 lg:pl-8">
          <p class="text-micro uppercase text-brand-dark-grey mb-8">Send a Message</p>
          <ContactForm />
        </div>

      </div>
    </div>
  </section>

</Base>
