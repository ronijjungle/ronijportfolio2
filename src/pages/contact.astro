---
// ─────────────────────────────────────────────────────────
// Contact — Bold CTA, personality-driven
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import ContactForm from "@components/ContactForm.astro";
import contact from "@data/contact.json";
---

<Base title="Contact" description="Get in touch with Ronij Barahi. Ambitious projects only.">

  <!-- Hero (BLACK) -->
  <section class="bg-brand-black">
    <div class="page-container pt-16 md:pt-26 pb-18 md:pb-30">
      <h1 class="text-display-lg text-brand-off-white max-w-4xl mb-8">Let&rsquo;s make<br />something that matters.</h1>
      <p class="text-body-xl text-brand-mid-grey max-w-2xl">
        Got a brand that needs building, a product that needs polish, or an idea that won&rsquo;t let you sleep? I&rsquo;m listening.
      </p>
    </div>
  </section>

  <!-- Contact grid (WHITE) -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8">

        <!-- Left: details -->
        <div class="lg:col-span-5">
          <div class="space-y-10">
            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-3">Drop a line</p>
              <a href={`mailto:${contact.email}`} class="text-heading-lg text-brand-black link-underline">
                {contact.email}
              </a>
            </div>

            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-3">Call me maybe</p>
              <a href={`tel:${contact.phone.replace(/\D/g, "")}`} class="text-heading text-brand-black link-underline">
                {contact.phone}
              </a>
            </div>

            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-3">Home base</p>
              <p class="text-body-lg text-brand-black">{contact.location}</p>
            </div>

            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-3">Status</p>
              <p class="text-body-lg text-brand-black">{contact.availability}</p>
            </div>

            <div>
              <p class="text-micro uppercase text-brand-dark-grey mb-4">Stalk me (politely)</p>
              <div class="flex flex-wrap gap-x-6 gap-y-2">
                {Object.entries(contact.social).map(([platform, url]) => (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-caption text-brand-dark-grey link-underline hover:text-brand-black"
                  >
                    {platform.charAt(0).toUpperCase() + platform.slice(1)}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div class="lg:col-span-7 lg:pl-8">
          <p class="text-micro uppercase text-brand-dark-grey mb-8">Or just fill this out</p>
          <ContactForm variant="light" />
        </div>

      </div>
    </div>
  </section>

</Base>
