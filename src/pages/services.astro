---
// ─────────────────────────────────────────────────────────
// Services — Bratus-style clean service listing
// Left: heading. Right: list of services with details.
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import { getCollection } from "astro:content";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="Services" description="Creative services by Ronij Barahi.">

  <!-- Hero -->
  <section class="page-container pt-16 md:pt-26 pb-18 md:pb-30">
    <div class="max-w-4xl">
      <h1 class="text-display-lg mb-8">What I can do for you</h1>
      <p class="text-body-xl text-brand-mid-grey max-w-2xl">
        End-to-end creative services from strategy to execution. Every engagement is tailored to your brand's unique needs.
      </p>
    </div>
  </section>

  <!-- Services list -->
  <section class="divider">
    <div class="page-container section-gap">
      <div class="reveal">
        {services.map(async (service, i) => {
          const { Content } = await service.render();
          return (
            <div class:list={["grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 py-10", i > 0 && "divider"]}>
              <div class="lg:col-span-1">
                <span class="text-micro text-brand-dark-grey">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </div>
              <div class="lg:col-span-4">
                <h3>{service.data.title}</h3>
              </div>
              <div class="lg:col-span-7">
                <p class="text-body text-brand-mid-grey mb-4">{service.data.description}</p>
                <div class="[&>p]:text-body [&>p]:text-brand-dark-grey [&>p]:leading-relaxed">
                  <Content />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="divider bg-brand-off-black">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <div class="lg:col-span-4">
          <h2>Process</h2>
        </div>
        <div class="lg:col-span-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10 reveal">
            {[
              { step: "01", title: "Discover", text: "Understanding your brand, audience, and goals through research and conversation." },
              { step: "02", title: "Define", text: "Translating insights into a clear creative strategy and project roadmap." },
              { step: "03", title: "Design", text: "Crafting visual solutions through iterative design and close collaboration." },
              { step: "04", title: "Deliver", text: "Finalizing assets and providing everything needed for seamless implementation." },
            ].map((item) => (
              <div>
                <span class="text-micro text-brand-dark-grey">{item.step}</span>
                <h4 class="mt-2 mb-3">{item.title}</h4>
                <p class="text-body text-brand-mid-grey">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="divider">
    <div class="page-container section-gap text-center">
      <h2 class="mb-6">Ready to start?</h2>
      <p class="text-body-lg text-brand-mid-grey mb-10 max-w-lg mx-auto">
        Every great project starts with a conversation.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-3 border border-brand-off-white text-brand-off-white text-caption font-semibold hover:bg-brand-off-white hover:text-brand-black transition-colors duration-200"
      >
        Get in Touch
      </a>
    </div>
  </section>

</Base>
