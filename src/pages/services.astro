---
// ─────────────────────────────────────────────────────────
// Services — Bold, opinionated copy
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import { getCollection } from "astro:content";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="Services" description="What Ronij Barahi actually does — and does well.">

  <!-- Hero (BLACK) -->
  <section class="bg-brand-black">
    <div class="page-container pt-16 md:pt-26 pb-18 md:pb-30">
      <div class="max-w-4xl">
        <h1 class="text-display-lg text-brand-off-white mb-8">Here&rsquo;s what I&rsquo;m<br />actually good at.</h1>
        <p class="text-body-xl text-brand-mid-grey max-w-2xl">
          Not a jack of all trades. A master of the ones that move the needle. Every engagement is built around your brand&rsquo;s specific goals — not a one-size-fits-all package.
        </p>
      </div>
    </div>
  </section>

  <!-- Services list (WHITE) -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container section-gap">
      <div class="reveal">
        {services.map(async (service, i) => {
          const { Content } = await service.render();
          return (
            <div class:list={["grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 py-10", i > 0 && "border-t border-brand-black/10"]}>
              <div class="lg:col-span-1">
                <span class="text-micro text-brand-dark-grey">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </div>
              <div class="lg:col-span-4">
                <h3 class="text-brand-black">{service.data.title}</h3>
              </div>
              <div class="lg:col-span-7">
                <p class="text-body text-brand-dark-grey mb-4">{service.data.description}</p>
                <div class="[&>p]:text-body [&>p]:text-brand-mid-grey [&>p]:leading-relaxed">
                  <Content />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Process (BLACK) -->
  <section class="bg-brand-black border-t border-brand-dark-grey/25">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <div class="lg:col-span-4">
          <h2 class="text-brand-off-white">How It<br />Actually Works</h2>
          <p class="text-body text-brand-mid-grey mt-4">No 47-step framework. Just a process that ships.</p>
        </div>
        <div class="lg:col-span-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10 reveal">
            {[
              { step: "01", title: "Listen", text: "I shut up and learn your brand, your audience, and your actual goals. Not what you think sounds good — what actually matters." },
              { step: "02", title: "Map It Out", text: "Insights become strategy. Strategy becomes a roadmap. You know exactly what's happening, when, and why." },
              { step: "03", title: "Build It", text: "Iterative design, tight feedback loops, zero disappearing acts. You see progress, not just a reveal at the end." },
              { step: "04", title: "Ship It", text: "Final assets, guidelines, handoffs — everything your team needs to run with it. Then I stick around to make sure nothing breaks." },
            ].map((item) => (
              <div>
                <span class="text-micro text-brand-dark-grey">{item.step}</span>
                <h4 class="text-brand-off-white mt-2 mb-3">{item.title}</h4>
                <p class="text-body text-brand-mid-grey">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA (WHITE) -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container section-gap text-center">
      <h2 class="text-brand-black mb-4">Sound like a fit?</h2>
      <p class="text-body-lg text-brand-dark-grey mb-10 max-w-lg mx-auto">
        I&rsquo;m not for everyone. But if you want work that actually performs — let&rsquo;s talk.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-3 bg-brand-black text-brand-off-white text-caption uppercase font-semibold hover:bg-brand-off-black transition-colors duration-200"
      >
        Start a project &rarr;
      </a>
    </div>
  </section>

</Base>
