---
// ─────────────────────────────────────────────────────────
// About — Bratus-style storytelling narrative
//
// Large typographic statement → narrative bio →
// stats → philosophy → clients
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import { getEntry, getCollection } from "astro:content";

const aboutEntry = await getEntry("about", "main");
const { Content } = await aboutEntry.render();
const { headline, subheadline, stats } = aboutEntry.data;

const testimonials = (await getCollection("testimonials")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="About" description="About Ronij Barahi — creative designer and brand strategist.">

  <!-- Hero statement -->
  <section class="page-container pt-16 md:pt-26 pb-18 md:pb-30">
    <h1 class="max-w-5xl">{headline}</h1>
  </section>

  <!-- Bio: 2-column layout -->
  <section class="divider">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-14 lg:gap-8">

        <!-- Left: portrait placeholder -->
        <div class="lg:col-span-5">
          <div class="aspect-[3/4] bg-brand-off-black border border-brand-dark-grey/15 flex items-center justify-center sticky top-24">
            <span class="text-heading text-brand-dark-grey/40">Portrait</span>
          </div>
        </div>

        <!-- Right: narrative -->
        <div class="lg:col-span-7 lg:pl-8">
          <p class="text-micro uppercase text-brand-dark-grey mb-6">{subheadline}</p>

          <div class="space-y-6 [&>p]:text-body-lg [&>p]:text-brand-mid-grey [&>p]:leading-relaxed">
            <Content />
          </div>

          <!-- Stats -->
          {stats.length > 0 && (
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-18 pt-10 divider">
              {stats.map((stat) => (
                <div>
                  <p class="text-display text-brand-off-white">{stat.value}</p>
                  <p class="text-micro uppercase text-brand-dark-grey mt-2">{stat.label}</p>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="divider bg-brand-off-black">
    <div class="page-container section-gap">
      <div class="max-w-3xl">
        <p class="text-micro uppercase text-brand-dark-grey mb-8">Philosophy</p>
        <blockquote class="text-display text-brand-light-grey font-light leading-snug">
          &ldquo;Design is not just what it looks like. Design is how it works, how it feels, and the story it tells.&rdquo;
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Clients / Testimonials -->
  <section class="divider">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <div class="lg:col-span-4">
          <h2>Clients</h2>
        </div>
        <div class="lg:col-span-8">
          <!-- Client logos (text placeholder) -->
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-18 reveal">
            {["Luxe Botanicals", "Nova Architecture", "Arc Festival", "Ember Studios", "Meridian Group", "Forma Collective"].map((name) => (
              <div class="py-6 divider flex items-center">
                <span class="text-heading text-brand-dark-grey font-semibold">{name}</span>
              </div>
            ))}
          </div>

          <!-- Quotes -->
          <div class="space-y-12 reveal">
            {testimonials.map((t) => (
              <blockquote class="divider pt-8">
                <p class="text-body-lg text-brand-light-grey italic mb-4 leading-relaxed">
                  &ldquo;{t.data.quote}&rdquo;
                </p>
                <footer class="flex items-center gap-2">
                  <cite class="not-italic text-caption text-brand-off-white font-medium">{t.data.name}</cite>
                  <span class="text-brand-dark-grey/40">/</span>
                  <span class="text-caption text-brand-dark-grey">{t.data.role}, {t.data.company}</span>
                </footer>
              </blockquote>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>
