---
// ─────────────────────────────────────────────────────────
// About — Bold, narrative, personality-driven
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import { getEntry, getCollection } from "astro:content";

const aboutEntry = await getEntry("about", "main");
const { Content } = await aboutEntry.render();
const { headline, subheadline, stats } = aboutEntry.data;

const testimonials = (await getCollection("testimonials")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="About" description="About Ronij Barahi — Creative Director, Co-Founder, and the person behind Jungle.">

  <!-- Hero statement (BLACK) -->
  <section class="bg-brand-black">
    <div class="page-container pt-16 md:pt-26 pb-18 md:pb-30">
      <h1 class="max-w-5xl text-brand-off-white">{headline}</h1>
      <p class="text-body-xl text-brand-mid-grey mt-6 max-w-2xl">
        The person brands call when &ldquo;good enough&rdquo; isn&rsquo;t.
      </p>
    </div>
  </section>

  <!-- Bio: 2-column layout (WHITE) -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-14 lg:gap-8">

        <!-- Portrait -->
        <div class="lg:col-span-5">
          <div class="aspect-[3/4] bg-brand-black/5 border border-brand-black/10 flex items-center justify-center sticky top-24">
            <span class="text-heading text-brand-black/20">Portrait</span>
          </div>
        </div>

        <!-- Narrative -->
        <div class="lg:col-span-7 lg:pl-8">
          <p class="text-micro uppercase text-brand-dark-grey mb-6">{subheadline}</p>

          <div class="space-y-6 [&>p]:text-body-lg [&>p]:text-brand-dark-grey [&>p]:leading-relaxed">
            <Content />
          </div>

          <!-- Stats -->
          {stats.length > 0 && (
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-18 pt-10 border-t border-brand-black/10">
              {stats.map((stat) => (
                <div>
                  <p class="text-display text-brand-black">{stat.value}</p>
                  <p class="text-micro uppercase text-brand-dark-grey mt-2">{stat.label}</p>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Experience / Credibility (BLACK) -->
  <section class="bg-brand-black border-t border-brand-dark-grey/25">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <div class="lg:col-span-4">
          <h2 class="text-brand-off-white">The Resume,<br />But Make It Short</h2>
        </div>
        <div class="lg:col-span-8">
          <div class="space-y-0 reveal">
            {[
              { role: "Creative Director & Co-Founder", company: "Jungle", period: "2020 – Present", note: "Built from zero to 100+ global clients. Still here. Still obsessing." },
              { role: "Lead Designer", company: "Volkswagen (via agency)", period: "2022", note: "Brand campaign work for one of the world's most recognized marks." },
              { role: "Brand Strategist", company: "Kantipur Media Group", period: "2021 – 2022", note: "Visual identity and strategic design for Nepal's largest media house." },
              { role: "Creative Lead", company: "Freelance & Agency Work", period: "2018 – 2020", note: "The \"figure it out\" years. Shipped fast. Learned faster." },
            ].map((item, i) => (
              <div class:list={["py-8", i > 0 && "divider"]}>
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-2">
                  <h4 class="text-brand-off-white">{item.role}</h4>
                  <span class="text-micro text-brand-dark-grey shrink-0">{item.period}</span>
                </div>
                <p class="text-caption text-brand-mid-grey">{item.company}</p>
                <p class="text-body text-brand-dark-grey mt-2">{item.note}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy (WHITE) -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container section-gap">
      <div class="max-w-3xl">
        <p class="text-micro uppercase text-brand-dark-grey mb-8">What I believe</p>
        <blockquote class="text-display text-brand-black font-light leading-snug">
          &ldquo;Strategy without design is a boardroom fantasy. Design without strategy is expensive decoration. I do both — so neither gets wasted.&rdquo;
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Clients / Testimonials (BLACK) -->
  <section class="bg-brand-black border-t border-brand-dark-grey/25">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <div class="lg:col-span-4">
          <h2 class="text-brand-off-white">People I&rsquo;ve<br />Worked With</h2>
          <p class="text-body text-brand-mid-grey mt-4">And what some of them said after.</p>
        </div>
        <div class="lg:col-span-8">
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-18 reveal">
            {["Volkswagen", "Kantipur", "Luxe Botanicals", "Nova Architecture", "Arc Festival", "Ember Studios"].map((name) => (
              <div class="py-6 divider flex items-center">
                <span class="text-heading text-brand-dark-grey font-semibold">{name}</span>
              </div>
            ))}
          </div>

          <div class="space-y-12 reveal">
            {testimonials.map((t) => (
              <blockquote class="divider pt-8">
                <p class="text-body-lg text-brand-light-grey italic mb-4 leading-relaxed">
                  &ldquo;{t.data.quote}&rdquo;
                </p>
                <footer class="flex items-center gap-2">
                  <cite class="not-italic text-caption text-brand-off-white font-medium">{t.data.name}</cite>
                  <span class="text-brand-dark-grey/40">/</span>
                  <span class="text-caption text-brand-dark-grey">{t.data.role}, {t.data.company}</span>
                </footer>
              </blockquote>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA (WHITE) -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container section-gap text-center">
      <h2 class="text-brand-black mb-4">Seen enough?</h2>
      <p class="text-body-lg text-brand-dark-grey mb-10 max-w-lg mx-auto">
        I&rsquo;m always up for a good project, a great conversation, or a terrible coffee recommendation.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-3 bg-brand-black text-brand-off-white text-caption uppercase font-semibold hover:bg-brand-off-black transition-colors duration-200"
      >
        Let&rsquo;s talk &rarr;
      </a>
    </div>
  </section>

</Base>
