---
// ─────────────────────────────────────────────────────────
// Portfolio — Bratus-style work grid
// Clean card layout, category + tags metadata per project.
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Extract unique categories for potential filtering
const categories = [...new Set(projects.map((p) => p.data.category))];
---

<Base title="Work" description="Selected projects by Ronij Barahi.">

  <section class="page-container section-gap">
    <!-- Header row -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14 md:mb-18">
      <div>
        <p class="text-micro uppercase text-brand-dark-grey mb-3">Portfolio</p>
        <h1 class="text-display-lg">Selected Work</h1>
      </div>
      <!-- Category labels -->
      <div class="flex flex-wrap gap-3">
        {categories.map((cat) => (
          <span class="text-caption text-brand-dark-grey border border-brand-dark-grey/25 px-3 py-1">
            {cat}
          </span>
        ))}
      </div>
    </div>

    <!-- Project Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-14 md:gap-y-18 reveal">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          category={project.data.category}
          year={project.data.year}
          tags={project.data.tags}
          slug={project.slug}
        />
      ))}
    </div>
  </section>

</Base>
