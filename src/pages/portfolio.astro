---
// ─────────────────────────────────────────────────────────
// Portfolio — Bratus-style work grid
// Clean card layout, category + tags metadata per project.
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Extract unique categories for potential filtering
const categories = [...new Set(projects.map((p) => p.data.category))];
---

<Base title="Work" description="Selected projects by Ronij Barahi.">

  <!-- Hero (BLACK) -->
  <section class="bg-brand-black">
    <div class="page-container pt-16 md:pt-26 pb-18 md:pb-30">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <p class="text-micro uppercase text-brand-dark-grey mb-3">The work</p>
          <h1 class="text-display-lg text-brand-off-white">Proof over promises.</h1>
          <p class="text-body text-brand-mid-grey mt-3 max-w-lg">Here&rsquo;s a selection of projects I&rsquo;m proud of. The rest are under NDA — or I&rsquo;d have to kill you.</p>
        </div>
        <!-- Category labels -->
        <div class="flex flex-wrap gap-3">
          {categories.map((cat) => (
            <span class="text-caption text-brand-dark-grey border border-brand-dark-grey/25 px-3 py-1">
              {cat}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Project Grid (WHITE) -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-14 md:gap-y-18 reveal">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            year={project.data.year}
            tags={project.data.tags}
            slug={project.slug}
            variant="light"
          />
        ))}
      </div>
    </div>
  </section>

</Base>
