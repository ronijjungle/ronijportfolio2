---
// ─────────────────────────────────────────────────────────
// Home Page — Bratus-style typography-driven hero
//
// Pattern: Large brand statement → values cloud →
// descriptor → secondary links → selected work grid
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="Home">

  <!-- ── Hero: Typography-driven brand statement ── -->
  <section class="page-container pt-16 md:pt-26 pb-22 md:pb-36">
    <div class="max-w-5xl">
      <!-- Core statement — bratus-style three-word concept -->
      <h1 class="mb-10 md:mb-14 animate-fade-up">
        Design.<br />
        Strategy.<br />
        Experience.
      </h1>

      <!-- Values / keyword cloud -->
      <div class="flex flex-wrap gap-x-4 gap-y-2 mb-12 md:mb-16 animate-fade-up" style="animation-delay: 150ms;">
        {["Intentional", "Minimal", "Functional", "Enduring", "Refined", "Purposeful", "Human", "Precise"].map((word) => (
          <span class="text-body-lg text-brand-dark-grey hover:text-brand-off-white transition-colors cursor-default">
            {word}
          </span>
        ))}
      </div>

      <!-- Descriptor -->
      <p class="text-body-xl text-brand-mid-grey max-w-2xl mb-10 animate-fade-up" style="animation-delay: 250ms;">
        Ronij Barahi is a multidisciplinary creative designer and brand strategist based in New York, working at the intersection of strategy and aesthetics.
      </p>

      <!-- Secondary links -->
      <div class="flex flex-wrap gap-x-8 gap-y-3 animate-fade-up" style="animation-delay: 350ms;">
        <a href="/services" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">Services</a>
        <a href="/about" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">Approach</a>
        <a href="/contact" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- ── Selected Work ── -->
  <section class="divider">
    <div class="page-container section-gap">
      <div class="flex items-baseline justify-between mb-14 md:mb-18">
        <h2>Selected Work</h2>
        <a href="/portfolio" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white hidden md:inline-block">
          View All
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-14 md:gap-y-18 reveal">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            year={project.data.year}
            tags={project.data.tags}
            slug={project.slug}
          />
        ))}
      </div>

      <div class="mt-14 md:hidden">
        <a href="/portfolio" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">
          View All Work
        </a>
      </div>
    </div>
  </section>

  <!-- ── Services overview (compact) ── -->
  <section class="divider">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <div class="lg:col-span-4">
          <h2>Services</h2>
        </div>
        <div class="lg:col-span-8">
          <div class="reveal">
            {services.map((service, i) => (
              <div class:list={["py-6 flex items-start gap-6", i > 0 && "divider"]}>
                <span class="text-micro text-brand-dark-grey mt-1 shrink-0 w-6">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div>
                  <h4 class="mb-2">{service.data.title}</h4>
                  <p class="text-body text-brand-mid-grey">{service.data.description}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-8">
            <a href="/services" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">
              Learn More
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>
