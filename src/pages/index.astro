---
// ─────────────────────────────────────────────────────────
// Home Page — Bold, personality-driven, bratus-style layout
// ─────────────────────────────────────────────────────────

import Base from "@layouts/Base.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);

const testimonials = (await getCollection("testimonials")).sort(
  (a, b) => a.data.order - b.data.order,
);
const featuredTestimonial = testimonials[0];
---

<Base title="Home" description="Ronij Barahi — Creative Director & Co-Founder at Jungle. Brand strategy, visual identity, and creative direction for 100+ global clients. Based in Kathmandu, Nepal.">

  <!-- ── HERO (BLACK) ── -->
  <section class="bg-brand-black">
    <div class="page-container pt-16 md:pt-26 pb-22 md:pb-36">
      <div class="max-w-5xl">
        <!-- Micro label -->
        <p class="text-micro uppercase text-brand-dark-grey mb-8 animate-fade-up">
          Creative Director &amp; Co-Founder &mdash; Kathmandu, Nepal
        </p>

        <!-- Main statement -->
        <h1 class="text-brand-off-white mb-10 md:mb-14 animate-fade-up" style="animation-delay: 100ms;">
          I don&rsquo;t make<br />
          pretty things.<br />
          I make them<br />
          <span class="text-brand-mid-grey">work.</span>
        </h1>

        <!-- Values cloud -->
        <div class="flex flex-wrap gap-x-4 gap-y-2 mb-12 md:mb-16 animate-fade-up" style="animation-delay: 200ms;">
          {["Strategy-first", "Globally tested", "Locally rooted", "No fluff", "All craft", "100+ clients deep"].map((word) => (
            <span class="text-body-lg text-brand-dark-grey hover:text-brand-off-white transition-colors cursor-default">
              {word}
            </span>
          ))}
        </div>

        <!-- Descriptor -->
        <p class="text-body-xl text-brand-mid-grey max-w-2xl mb-10 animate-fade-up" style="animation-delay: 300ms;">
          Creative Director who built a studio, scaled it to 100+ global clients, and still obsesses over kerning at 2 AM. Currently leading the creative chaos at <a href="https://fromjungle.co/" target="_blank" rel="noopener noreferrer" class="text-brand-off-white link-underline">Jungle</a>.
        </p>

        <!-- Secondary links -->
        <div class="flex flex-wrap gap-x-8 gap-y-3 animate-fade-up" style="animation-delay: 400ms;">
          <a href="/portfolio" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">See the work</a>
          <a href="/about" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">The backstory</a>
          <a href="/contact" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">Let&rsquo;s talk</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CREDIBILITY BAR (WHITE) ── -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container py-10 md:py-14">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div>
          <p class="text-display text-brand-black">100+</p>
          <p class="text-micro uppercase text-brand-dark-grey mt-1">Global clients</p>
        </div>
        <div>
          <p class="text-display text-brand-black">10+</p>
          <p class="text-micro uppercase text-brand-dark-grey mt-1">Designers led</p>
        </div>
        <div>
          <p class="text-display text-brand-black">7+</p>
          <p class="text-micro uppercase text-brand-dark-grey mt-1">Years in the game</p>
        </div>
        <div>
          <p class="text-display text-brand-black">∞</p>
          <p class="text-micro uppercase text-brand-dark-grey mt-1">Cups of coffee</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SELECTED WORK (BLACK) ── -->
  <section class="bg-brand-black border-t border-brand-dark-grey/25">
    <div class="page-container section-gap">
      <div class="flex items-baseline justify-between mb-14 md:mb-18">
        <div>
          <h2 class="text-brand-off-white">Selected Work</h2>
          <p class="text-body text-brand-mid-grey mt-3">The ones I&rsquo;m actually allowed to show you.</p>
        </div>
        <a href="/portfolio" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white hidden md:inline-block">
          See all
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-14 md:gap-y-18 reveal">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            year={project.data.year}
            tags={project.data.tags}
            slug={project.slug}
            variant="dark"
          />
        ))}
      </div>

      <div class="mt-14 md:hidden">
        <a href="/portfolio" class="text-caption text-brand-mid-grey link-underline hover:text-brand-off-white">
          See all work &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ── SERVICES (WHITE) ── -->
  <section class="bg-brand-off-white border-t border-brand-black/10">
    <div class="page-container section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <div class="lg:col-span-4">
          <h2 class="text-brand-black">What I Do</h2>
          <p class="text-body text-brand-dark-grey mt-4">
            Not a jack of all trades.<br />A master of the ones that matter.
          </p>
        </div>
        <div class="lg:col-span-8">
          <div class="reveal">
            {services.map((service, i) => (
              <div class:list={["py-6 flex items-start gap-6", i > 0 && "border-t border-brand-black/10"]}>
                <span class="text-micro text-brand-dark-grey mt-1 shrink-0 w-6">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div>
                  <h4 class="text-brand-black mb-2">{service.data.title}</h4>
                  <p class="text-body text-brand-dark-grey">{service.data.description}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-8">
            <a href="/services" class="text-caption text-brand-dark-grey link-underline hover:text-brand-black">
              The full menu &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PHILOSOPHY (BLACK) ── -->
  <section class="bg-brand-black border-t border-brand-dark-grey/25">
    <div class="page-container section-gap">
      <div class="max-w-3xl">
        <p class="text-micro uppercase text-brand-dark-grey mb-8">Philosophy</p>
        <blockquote class="text-display text-brand-light-grey font-light leading-snug">
          &ldquo;Good design is obvious. Great design is invisible. But the best design? It makes people feel something they can&rsquo;t quite explain &mdash; and then buy the thing.&rdquo;
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIAL (WHITE) ── -->
  {featuredTestimonial && (
    <section class="bg-brand-off-white border-t border-brand-black/10">
      <div class="page-container section-gap">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-micro uppercase text-brand-dark-grey mb-8">Kind words</p>
          <p class="text-display text-brand-black font-light leading-snug mb-8">
            &ldquo;{featuredTestimonial.data.quote}&rdquo;
          </p>
          <div>
            <p class="text-caption font-semibold text-brand-black">{featuredTestimonial.data.name}</p>
            <p class="text-micro text-brand-dark-grey mt-1">
              {featuredTestimonial.data.role}, {featuredTestimonial.data.company}
            </p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── CTA (BLACK) ── -->
  <section class="bg-brand-black border-t border-brand-dark-grey/25">
    <div class="page-container section-gap text-center">
      <p class="text-micro uppercase text-brand-dark-grey mb-6">What are you waiting for?</p>
      <h2 class="text-brand-off-white mb-4">Got a project?<br />Let&rsquo;s make it dangerous.</h2>
      <p class="text-body-lg text-brand-mid-grey mb-10 max-w-lg mx-auto">
        I&rsquo;m always down for ambitious brands, wild ideas, and people who don&rsquo;t settle for &ldquo;good enough.&rdquo;
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-8 py-3 bg-brand-off-white text-brand-black text-caption uppercase font-semibold hover:bg-brand-light-grey transition-colors duration-200"
        >
          Start something &rarr;
        </a>
        <a
          href="mailto:hello@ronijbarahi.com"
          class="inline-flex items-center gap-2 px-8 py-3 border border-brand-dark-grey/40 text-brand-mid-grey text-caption uppercase font-semibold hover:border-brand-off-white hover:text-brand-off-white transition-colors duration-200"
        >
          Or just say hi
        </a>
      </div>
    </div>
  </section>

</Base>
